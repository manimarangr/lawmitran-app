# Database
DATABASE_URL=postgresql://lawmitran:lawmitran@localhost:5432/lawmitran?schema=public
POSTGRES_USER=lawmitran
POSTGRES_PASSWORD=lawmitran
POSTGRES_DB=lawmitran

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lawmitran-documents
S3_ACCESS_KEY=lawmitran
S3_SECRET_KEY=lawmitran123
S3_FORCE_PATH_STYLE=true

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend
PORT=3001
NODE_ENV=development

# Rate limiting (default tier; sensitive auth routes set their own stricter limits)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# reCAPTCHA (leave blank in dev to bypass verification)
RECAPTCHA_SECRET_KEY=

# Razorpay (leave blank in dev to bypass real payment verification; UPI is a payment method within Razorpay Checkout, no separate integration needed)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
API_INTERNAL_URL=http://backend:3001/api
