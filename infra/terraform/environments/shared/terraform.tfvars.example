# Copy to terraform.tfvars and fill in. terraform.tfvars is git-ignored.

admin_cidrs   = ["203.0.113.10/32"]     # your office / VPN IP
key_name      = "lawmitran-shared"      # existing EC2 key pair name
instance_type = "t3.medium"
zone_name     = "lawmitran.com"
alert_email   = "ops@lawmitran.com"     # or omit to skip CloudWatch alerts
